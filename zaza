-- Global Player Search Helper with Fuzzy Matching
local function getPlayerFromSearch(str)
    if not str or str == "" then return nil end
    str = str:lower()
    
    local players = plrs:GetPlayers()
    if #players == 0 then return nil end

    -- First pass: check for exact starts with
    for _, p in ipairs(players) do
        if p.Name:lower():sub(1, #str) == str or p.DisplayName:lower():sub(1, #str) == str then
            return p
        end
    end
    
    -- Second pass: check for anywhere in name (plain text, no patterns)
    for _, p in ipairs(players) do
        if p.Name:lower():find(str, 1, true) or p.DisplayName:lower():find(str, 1, true) then
            return p
        end
    end
    
    -- Third pass: Fuzzy match for closest string distance (Levenshtein)
    local closestPlayer = nil
    local bestScore = math.huge
    
    local function getDistance(s1, s2)
        if #s1 == 0 then return #s2 end
        if #s2 == 0 then return #s1 end
        local matrix = {}
        for i = 0, #s1 do matrix[i] = {[0] = i} end
        for j = 0, #s2 do matrix[0][j] = j end
        for i = 1, #s1 do
            for j = 1, #s2 do
                local cost = (s1:sub(i, i) == s2:sub(j, j) and 0 or 1)
                matrix[i][j] = math.min(matrix[i-1][j] + 1, matrix[i][j-1] + 1, matrix[i-1][j-1] + cost)
            end
        end
        return matrix[#s1][#s2]
    end
    
    for _, p in ipairs(players) do
        local d1 = getDistance(str, p.Name:lower())
        local d2 = getDistance(str, p.DisplayName:lower())
        local minD = math.min(d1, d2)
        
        if minD < bestScore then
            bestScore = minD
            closestPlayer = p
        end
    end
    
    return closestPlayer
end

-- Formatting: Username outside, DisplayName inside brackets (Max 7 chars each)
local function formatPlayerName(p)
    local username = p.Name
    local display = p.DisplayName
    
    if #username > 7 then
        username = username:sub(1, 7) .. "..."
    end
    
    if #display > 7 then
        display = display:sub(1, 7) .. "..."
    end
    
    return username .. " (" .. display .. ")"
end

local function getVoidState()
    if Toggles.manualvoid and Toggles.manualvoid.Value then
        if char and char:FindFirstChild("[Flamethrower]") then
            return false
        end
        if char then
            for _, v in ipairs(char:GetChildren()) do
                if v:IsA("Tool") and v.Name:lower():find("bag") then
                    return false
                end
            end
        end
        return true
    end
    return false
end

local function hasFlame(p)
    if not p or not p.Character then return false end
    local t = p.Character:FindFirstChildOfClass("Tool")
    return t and t.Name == "[Flamethrower]"
end

local function isReloading(p)
    local s = api:get_status_cache(p)
    return s and s.Reload
end

local function isBagged(p)
    if not p or not p.Character then return false end
    return p.Character:FindFirstChild("Christmas_Sock") ~= nil
end

local function isKOd(p)
    local s = api:get_status_cache(p)
    return s and s["K.O"]
end

local function isDead(p)
    if not p or not p.Character then return true end
    local hum = p.Character:FindFirstChild("Humanoid")
    if not hum or hum.Health <= 0 then return true end
    return false
end

local function hasFF(p)
    return p and p.Character and p.Character:FindFirstChildOfClass("ForceField")
end

local function isThreat(p)
    if not p or not p.Character then return false end
    if isBagged(p) then return false end
    if hasFlame(p) and not isReloading(p) then return true end
    return false
end

local function isVulnerable(p)
    if not p or not p.Character then return false end
    if isBagged(p) or isKOd(p) then return false end
    return hasFlame(p) and isReloading(p)
end

local function unequipBag()
    local bp = plr:FindFirstChildOfClass("Backpack")
    if not bp then return end
    for _, v in pairs(char:GetChildren()) do
        if v:IsA("Tool") and v.Name:lower():find("bag") then
            v.Parent = bp
        end
    end
end

local function unequipAll()
    local bp = plr:FindFirstChildOfClass("Backpack")
    if not bp then return end
    for _, v in pairs(char:GetChildren()) do
        if v:IsA("Tool") then
            v.Parent = bp
        end
    end
end

local function cleanupAutobag(preserveDesync)
    if autobagstates.target and autobagstates.target.Part then
        autobagstates.target.Part.Anchored = false
    end
    autobagstates.target, autobagstates.active = nil, false
    autobagstates.downing = false
    autobagstates.ffHiding = false
    autobagstates.bagPosition = nil
    sethiddenproperty(hrp, "PhysicsRepRootPart", nil)
    unequipBag()
    if preserveDesync then
        api:set_desync_cframe(CFrame.new(9e9, 9e9, 9e9))
    else
        api:set_desync_cframe(nil)
    end
end

local function addToRagebotTargets(playerName)
    local rbtargets = api:get_ui_object("ragebot_targets")
    if rbtargets then
        local val = {}
        for k, v in pairs(rbtargets.Value or {}) do
            val[k] = v
        end
        val[playerName] = true
        rbtargets:SetValue(val)
    end
    local useSelected = api:get_ui_object("ragebot_use_selected")
    if useSelected then
        useSelected:SetValue(true)
    end
end

local function removeFromRagebotTargets(playerName)
    local rbtargets = api:get_ui_object("ragebot_targets")
    if rbtargets then
        local val = {}
        for k, v in pairs(rbtargets.Value or {}) do
            val[k] = v
        end
        val[playerName] = nil
        rbtargets:SetValue(val)
    end
end

local function goHide()
    api:set_ragebot(false)
    cleanupAutobag(true)
    protectionstate.hiding = true
    api:set_desync_cframe(CFrame.new(9e9, 9e9, 9e9))
end

local function stopHide()
    protectionstate.hiding = false
    local isVoidOn = getVoidState()
    if isVoidOn then
        api:set_desync_cframe(CFrame.new(9e9, 9e9, 9e9))
    else
        api:set_desync_cframe(nil)
    end
end

local function getBags()
    local bags = {}
    local bp = plr:FindFirstChildOfClass("Backpack")
    for _, v in ipairs(bp and bp:GetChildren() or {}) do
        if v:IsA("Tool") and v.Name:lower():find("bag") then
            table.insert(bags, v)
        end
    end
    for _, v in ipairs(char:GetChildren()) do
        if v:IsA("Tool") and v.Name:lower():find("bag") then
            table.insert(bags, 1, v)
        end
    end
    return bags
end

