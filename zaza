local function hookChar(c, p)
    local function tryHook(animator)
        if not animator or not animator:IsA("Animator") then return end
        animator.AnimationPlayed:Connect(function(t)
            if t.Animation.AnimationId == "rbxassetid://3493406987" then
                if Toggles.antibag.Value then
                    protectionstate.bagThreat = true
                    t.Stopped:Once(function()
                        protectionstate.bagThreat = false
                    end)
                end
            end
        end)
    end
    for _, d in ipairs(c:GetDescendants()) do
        if d:IsA("Animator") then
            tryHook(d)
        end
    end
    c.DescendantAdded:Connect(function(d)
        if d:IsA("Animator") then
            tryHook(d)
        end
    end)
end

local function hookPlayer(p)
    if p.Character then hookChar(p.Character, p) end
    p.CharacterAdded:Connect(function(c) hookChar(c, p) end)
end

for _, p in pairs(plrs:GetPlayers()) do
    if p ~= plr then hookPlayer(p) end
end

plrs.PlayerAdded:Connect(function(p)
    if p ~= plr then hookPlayer(p) end
end)

plr.CharacterAdded:Connect(onCharacterAdded)
if char then onCharacterAdded(char) end

api:add_connection(runs.Heartbeat:Connect(function()
    char = plr.Character or char
    hrp = char and char:FindFirstChild("HumanoidRootPart") or hrp
    if not hrp then return end

    local isAutobagOn = Toggles.autobag and Toggles.autobag.Value

    if tick() - resetDebounce > 0.5 then
        if isBagged(plr) then
            resetDebounce = tick()
            local hum = char:FindFirstChild("Humanoid")
            if hum and hum.Health > 0 then
                hum.Health = 0
            end
            return
        end
    end

    -- Autoheal Logic (Overrides everything else when triggered)
    if Toggles.autoheal and Toggles.autoheal.Value then
        local hum = char:FindFirstChild("Humanoid")
        if hum and hum.Health > 0 and hum.MaxHealth > 0 then
            local bp = plr:FindFirstChildOfClass("Backpack")
            local burger = char:FindFirstChild("[Hamburger]") or (bp and bp:FindFirstChild("[Hamburger]"))
            
            -- Proactively buy the burger if we don't have one in inventory
            if not burger then
                if tick() - protectionstate.burgerLastBought > 2 then
                    protectionstate.burgerLastBought = tick()
                    api:buy_item("[Hamburger]", false, true)
                end
            end

            local hpPercent = (hum.Health / hum.MaxHealth) * 100
            
            -- Enter healing state if HP falls below threshold
            if hpPercent <= Options.heal_threshold.Value then
                protectionstate.healing = true
            end
            
            -- Exit healing state ONLY when HP reaches 100%
            if hpPercent >= 99.9 then
                protectionstate.healing = false
            end
            
            -- Perform healing actions while in healing state
            if protectionstate.healing then
                api:set_ragebot(false)
                
                if burger then
                    -- Make sure only the hamburger is equipped, void, and eat
                    unequipAll()
                    burger.Parent = char
                    api:set_desync_cframe(CFrame.new(9e9, 9e9, 9e9))
                    burger:Activate()
                end
                
                -- Block all other tasks from running while we heal
                return 
            end
        else
            -- Reset if dead
            protectionstate.healing = false
        end
    else
        protectionstate.healing = false
    end

    local anyFlameThreat = false
    local anyVulnerable = false
    local shouldHide = false

    if Toggles.antiflame.Value then
        for name, enabled in pairs(Options.antiflametargets.Value or {}) do
            local p = plrs:FindFirstChild(name)
            if enabled and p and p.Character then
                if isThreat(p) then anyFlameThreat = true end
                if isVulnerable(p) then anyVulnerable = true end
            end
        end
        if anyFlameThreat then shouldHide = true end
    end

    if Toggles.antibag.Value and protectionstate.bagThreat then
        shouldHide = true
    end

    if shouldHide then
        goHide()
        return
    else
        if protectionstate.hiding then
            if isAutobagOn then
                stopHide()
            else
                if anyVulnerable then
                    stopHide()
                    api:set_ragebot(true)
                else
                    stopHide()
                end
            end
        end
        if anyVulnerable and not isAutobagOn then
            api:set_ragebot(true)
        end
    end

    if Toggles.autofirearmor.Value then
        local cache = api:get_status_cache(plr)
        local armor = 0
        if cache then armor = cache.FireArmor or 0 end
        local percent = math.clamp((armor / 200) * 100, 0, 100)
        
        if percent <= Options.firearmor_threshold.Value then
            if tick() - protectionstate.fireArmorLastBought > 2 then
                protectionstate.fireArmorLastBought = tick()
                api:buy_item("[Fire Armor]", false, true)
            end
        end
    end

    if autobagstates.target and autobagstates.target.Player then
        local tName = autobagstates.target.Player.Name
        if not Options.autobagtargets.Value or not Options.autobagtargets.Value[tName] then
            local doVoid = getVoidState() or protectionstate.hiding
            cleanupAutobag(doVoid)
        end
    end

    if not isAutobagOn then
        local doVoid = getVoidState() or protectionstate.hiding
        cleanupAutobag(doVoid)
        return
    end

    local bags = getBags()
    if #bags == 0 then
        if tick() - autobagstates.lastbought > 2 then
            autobagstates.lastbought = tick()
            api:buy_item("[BrownBag]")
        end
        return
    end

    local vulnerable = {}
    local normal = {}

    if latestSelectedTarget and Options.autobagtargets.Value and Options.autobagtargets.Value[latestSelectedTarget] then
        local p = plrs:FindFirstChild(latestSelectedTarget)
        if p and p.Character and not isDead(p) then
            local kod = isKOd(p)
            local bagged = isBagged(p)
            
            if kod or bagged then
                table.insert(vulnerable, 1, p)
            elseif isVulnerable(p) then
                table.insert(vulnerable, 1, p)
            elseif not isThreat(p) then
                table.insert(normal, 1, p)
            end
        end
    end

    for name, enabled in pairs(Options.autobagtargets.Value or {}) do
        if name ~= latestSelectedTarget then
            local p = plrs:FindFirstChild(name)
            if enabled and p and p.Character and not isDead(p) then
                local kod = isKOd(p)
                local bagged = isBagged(p)
                
                if kod or bagged then
                    table.insert(vulnerable, p)
                elseif isVulnerable(p) then
                    table.insert(vulnerable, p)
                elseif not isThreat(p) then
                    table.insert(normal, p)
                end
            end
        end
    end

    if autobagstates.downing and autobagstates.target then
        local targetPlayer = autobagstates.target.Player
        
        if isDead(targetPlayer) or not targetPlayer.Character then
            api:set_ragebot(false)
            unequipAll()
            if not protectionstate.hiding then
                api:set_desync_cframe(nil)
            end
            return
        end

        if not isBagged(targetPlayer) and not isKOd(targetPlayer) then
            if hasFF(targetPlayer) then
                api:set_ragebot(false)
                unequipAll()
                if getVoidState() and not protectionstate.hiding then
                    api:set_desync_cframe(CFrame.new(9e9, 9e9, 9e9))
                end
                return
            else
                autobagstates.downing = false
                autobagstates.ffHiding = false
                if getVoidState() and not protectionstate.hiding then
                    api:set_desync_cframe(CFrame.new(9e9, 9e9, 9e9))
                elseif not protectionstate.hiding then
                    api:set_desync_cframe(nil)
                end
            end
        else
            if isKOd(targetPlayer) then
                unequipBag()
                api:set_ragebot(true)
                if not protectionstate.hiding then
                    api:set_desync_cframe(nil)
                end
                return
            end
            
            if hasFF(targetPlayer) then
                if not autobagstates.ffHiding then
                    autobagstates.ffHiding = true
                end
                api:set_ragebot(false)
                if not protectionstate.hiding then
                    api:set_desync_cframe(CFrame.new(9e9, 9e9, 9e9))
                end
            else
                if autobagstates.ffHiding then
                    autobagstates.ffHiding = false
                    if not protectionstate.hiding then
                        api:set_desync_cframe(nil)
                    end
                end
                unequipBag()
                api:set_ragebot(true)
            end
            return
        end
    end

    if autobagstates.target and not autobagstates.downing and (isBagged(autobagstates.target.Player) or isKOd(autobagstates.target.Player)) then
        local tp = autobagstates.target.Player

        addToRagebotTargets(tp.Name)
        if autobagstates.target.Part then
            autobagstates.target.Part.Anchored = false
        end
        sethiddenproperty(hrp, "PhysicsRepRootPart", nil)
        unequipBag()
        autobagstates.downing = true
        autobagstates.ffHiding = false
        
        if getVoidState() and not protectionstate.hiding then
            api:set_desync_cframe(CFrame.new(9e9, 9e9, 9e9))
        elseif not protectionstate.hiding then
            api:set_desync_cframe(nil)
        end
        
        if not hasFF(tp) then
            api:set_ragebot(true)
        end
        return
    end

    local targetPlayer = nil
    if #vulnerable > 0 then
        targetPlayer = vulnerable[1]
    elseif #normal > 0 then
        targetPlayer = normal[1]
    end

    if not targetPlayer then
        local doVoid = getVoidState() or protectionstate.hiding
        cleanupAutobag(doVoid)
        return
    end

    api:set_ragebot(false)

    local needSwitch = false
    if not autobagstates.target then
        needSwitch = true
    elseif autobagstates.target.Player ~= targetPlayer then
        needSwitch = true
    elseif tick() - autobagstates.start > 5 then
        needSwitch = true
    end

    if needSwitch then
        if autobagstates.target and autobagstates.target.Part then
            autobagstates.target.Part.Anchored = false
        end
        autobagstates.target = {
            Player = targetPlayer
        }
        autobagstates.start = tick()
        
        if hrp.Position.Y < 500000 then
            autobagstates.bagPosition = hrp.Position
        end
        
        if getVoidState() and not protectionstate.hiding then
            api:set_desync_cframe(CFrame.new(9e9, 9e9, 9e9))
        elseif not protectionstate.hiding then
            api:set_desync_cframe(nil)
        end
    end

    if isKOd(autobagstates.target.Player) or isBagged(autobagstates.target.Player) then
        return
    end

    local tChar = autobagstates.target.Player.Character
    local tPart = tChar and (tChar:FindFirstChild("HumanoidRootPart") or tChar:FindFirstChildWhichIsA("BasePart"))
    if not tPart then
        return
    end
    autobagstates.target.Part = tPart

    local tool = char:FindFirstChildWhichIsA("Tool")
    if not (tool and tool.Name:lower():find("bag")) then
        tool = bags[1]
